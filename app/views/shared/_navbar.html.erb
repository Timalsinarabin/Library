<ul class="nav nav-tabs my-2 mx-5 " id="myTab" role="tablist">
  <li class="nav-item">
    <%= link_to "Home", "/", class: "nav-link text-dark" %>
  </li>
  <li class="nav-item">
    <%= link_to "About", about_path, class: "nav-link text-dark" %>
  </li>
  <% if Current.user %>
    <li class="nav-item nav-link ms-auto text-dark">
      <nav class="navbar navbar-expand-xxl">
        <div class="container-fluid gap-4">
          <%= Current.user.username%>
          <div class="navbar-toggler" type="button" 
            data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-icon"></span>
          </div>
            <div class="collapse navbar-collapse w-auto"       id="navbarNavAltMarkup">
              <div class="navbar-nav">
                <%= link_to "Change password", changepassword_path, class: "nav-link text-dark" %>
                <%= link_to "logout", logout_path, data: {  turbo_method: :delete }, class: "nav-link text-dark" %>
              </div>
            </div>
        </div>
      </nav>

  <%else%>
    <li class="nav-item ms-auto">
      <%= link_to "Sign up", sign_up_path, class: "nav-link text-dark" %>
    </li>
    <li class="nav-item">
      <%= link_to "Sign in", sign_in_path, class: "nav-link text-dark" %>
    </li>
  <%end%>
</ul>

<div class="tab-content" id="myTabContent">
  <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab"></div>
  <div class="tab-pane fade " id="login" role="tabpanel" aria-labelledby="login-tab"></div>
  <div class="tab-pane fade" id="about" role="tabpanel" aria-labelledby="about-tab"></div>
</div> 