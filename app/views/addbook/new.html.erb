<h1 class="display-4 m-4">Add a book</h1>
<div class="container m-4">
<%= form_with model: @add_book, url: add_book_path, method: :post, local: true do |form| %>
  <div class="form-group">
    <%= form.label :bookname, "Book Name" %>
    <%= form.text_field :bookname, class: "form-control", required: true %>
  </div>
  <div class="form-group">
    <%= form.label :author, "Author" %>
    <%= form.text_field :author, class: "form-control", required: true %>
  </div>
    <div class="form-group">
    <%= form.label :price, "Price" %>
    <%= form.text_field :price, class: "form-control", required: true %>
  </div>
  <%= form.submit "Add Book", class: "btn btn-primary mt-2" %>
<% end %>
</div>