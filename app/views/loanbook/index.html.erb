<main class="container d-flex flex-column align-items-center justify-content-center mt-5">
    <h1>Loan a book</h1>
    <%= form_with model: @loan, url: loan_book_path, method: :post, local: true do |form|%>
        <div class="form-row mt-4">
            <div class="form-group">
              <%= form.label :std_id, "Student Id" %>
              <%= form.text_field :std_id, class: "form-control", placeholder: "Student Id" %>
            </div>
            <div class="form-group mt-4">
              <%= form.label :bookname, "Bookname" %>
              <%= form.text_field :bookname, class: "form-control", placeholder: "Book Name" %>
            </div>
        </div> 
        <div class="form-row d-flex justify-content-center mt-4">
            <%= form.submit "loan Book", class: "btn btn-primary" %>
        </div>
    <%end%>
</main>