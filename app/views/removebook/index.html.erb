<h1 class="display-4 m-4">All Books</h1>
<table class="table table-striped m-4">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        <% @destroy_books.each do |book| %>
            <tr>
                <td><%= book.bookname %></td>
                <td><%= book.author %></td>
                <td>
                    <%= button_to "Remove", remove_path(book), method: :delete, class: "btn btn-danger" %>
                </td>
            </tr>
        <% end %>
    </tbody>
</table>