<h1 class="display-4 m-4">All Books</h1>
<%= form_with url: viewall_books_path, method: :get, local: true do |form| %>
  <div class="form-group m-2 ms-4 w-50">
    <%= form.label :search, "Book Name" %>
    <%= form.text_field :search, class: "form-control", required: true %>
  </div>
  <%= form.submit "Search Book", class: "btn btn-primary mt-2 ms-4" %>
<% end %>    
<table class="table table-striped m-4">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        <%if @books.any?%>
            <% @books.each do |book| %>
                <tr>
                    <td><%= book.bookname %></td>
                    <td><%= book.author %></td>
                    <td><%= book.price %></td>
                </tr>
            <% end %>
        <%else%>
            <tr>
                <td>Book not found</td>
            </tr>
        <%end%>
    </tbody>
</table>
