
<div class="container d-flex flex-column align-items-center justify-content-center mt-5">
    <h1>Register Now</h1>
    <%= form_with url: sign_up_path, model: @user, method: "post",local: true do |form| %>
    <% if @user.errors.any? %>
        <div class="alert alert-danger">
            <ul>
                <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                <% end %>
            </ul>
        </div>
    <% end %>
        <div class="form-row mt-4">
            <div class="form-group">
              <%= form.label :username, "Username" %>
              <%= form.text_field :username, class: "form-control", placeholder: "Username" %>
            </div>
            <div class="form-group mt-4">
              <%= form.label :password, "Password" %>
              <%= form.password_field :password, class: "form-control", placeholder: "Password" %>
            </div>
            <div class="form-group mt-4">
              <%= form.label :password_confirmation, "Confirm Password" %>
              <%= form.password_field :password_confirmation, class: "form-control", placeholder: "Confirm Password" %>
            </div>
        </div> 
        <div class="form-row d-flex justify-content-center mt-4">
            <%= form.submit "Register", class: "btn btn-primary" %>
        </div>
    <% end %>
</div>