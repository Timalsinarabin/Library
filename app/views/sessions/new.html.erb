
<div class="container d-flex flex-column align-items-center justify-content-center mt-5">
    <h1>Log In</h1>
    <%= form_with url: sign_in_path, method: "post",local: true do |form| %>
        <div class="form-row mt-4">
            <div class="form-group">
              <%= form.label :username, "Username" %>
              <%= form.text_field :username, class: "form-control", placeholder: "Username" %>
            </div>
            <div class="form-group mt-4">
              <%= form.label :password, "Password" %>
              <%= form.password_field :password, class: "form-control", placeholder: "Password" %>
            </div>
        </div> 
        <div class="form-row d-flex justify-content-center mt-4">
            <%= form.submit "login", class: "btn btn-primary" %>
        </div>
    <% end %>
    <div class="mt-3">
        <p>Don't have an account? <%= link_to "Register here", sign_up_path %></p>
    </div>
</div>